@Article{Moleon2008,
  abstract = {Hyperpredation refers to an enhanced predation pressure on a secondary prey due to either an increase in the abundance of a predator population or a sudden drop in the abundance of the main prey. This scarcely documented mechanism has been previously studied in scenarios in which the introduction of a feral prey caused overexploitation of native prey. Here we provide evidence of a previously unreported link between Emergent Infectious Diseases (EIDs) and hyperpredation on a predator-prey community. We show how a viral outbreak caused the population collapse of a host prey at a large spatial scale, which subsequently promoted higher-than-normal predation intensity on a second prey from shared predators. Thus, the disease left a population dynamic fingerprint both in the primary host prey, through direct mortality from the disease, and indirectly in the secondary prey, through hyperpredation. This resulted in synchronized prey population dynamics at a large spatio-temporal scale. We therefore provide evidence for a novel mechanism by which EIDs can disrupt a predator-prey interaction from the individual behavior to the population dynamics. This mechanism can pose a further threat to biodiversity through the human-aided disruption of ecological interactions at large spatial and temporal scales.},
  author = {Marcos Mole{\a'o}n and Pablo Almaraz and Jos{\a'e} A. S{\a'a}nchez-Zapata},
  doi = {10.1371/journal.pone.0002307},
  file = {:home/pablo/Mendeley/Mole{\'{o}}n, Almaraz, S{\'{a}}nchez-Zapata - 2008 - An Emerging Infectious Disease Triggering Large-Scale Hyperpredation.pdf:pdf},
  isbn = {1932-6203},
  issn = {1932-6203},
  journal = {PLoS ONE},
  month = {jun},
  number = {6},
  pages = {e2307},
  title = {{An Emerging Infectious Disease Triggering Large-Scale Hyperpredation}},
  url = {http://dx.plos.org/10.1371/journal.pone.0002307},
  volume = {3},
  year = {2008},
  editor = {Wayne M. Getz},
  pmid = {18523587},
  date = {2008-01-01},
}
